{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/*.css",
			"!dist",
			"!**/node_modules",
			"!**/build",
			"!**/.next",
			"!**/.vercel",
			"!**/.wrangler",
			"!**/cloudflare/frontend/.next",
			"!**/cloudflare/frontend/.vercel",
			"!**/cloudflare/frontend/.open-next",
			"!**/cloudflare/.wrangler",
			"!**/cloudflare/.cloudflare",
			"!**/.vscode",
			"!**/.claude"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"css": {
		"parser": {
			"cssModules": true,
			"allowWrongLineComments": true
		},
		"linter": {
			"enabled": false
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
